---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- set pages = [
  { url: "/",                 priority: "1.0", changefreq: "weekly"  },
  { url: "/about/",           priority: "0.8", changefreq: "monthly" },
  { url: "/living-options/",  priority: "0.9", changefreq: "monthly" },
  { url: "/amenities/",       priority: "0.9", changefreq: "monthly" },
  { url: "/floor-plans/",     priority: "0.9", changefreq: "monthly" },
  { url: "/gallery/",         priority: "0.7", changefreq: "monthly" },
  { url: "/contact/",         priority: "0.9", changefreq: "monthly" },
  { url: "/privacy/",         priority: "0.2", changefreq: "yearly"  },
  { url: "/accessibility/",   priority: "0.2", changefreq: "yearly"  }
] -%}
{%- set buildDate = page.date.toISOString().slice(0, 10) -%}
{%- for p in pages %}
  <url>
    <loc>{{ site.url }}{{ p.url }}</loc>
    <lastmod>{{ buildDate }}</lastmod>
    <changefreq>{{ p.changefreq }}</changefreq>
    <priority>{{ p.priority }}</priority>
  </url>
{%- endfor %}
</urlset>
