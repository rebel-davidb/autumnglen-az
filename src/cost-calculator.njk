    color: var(--c-ink);
  }
  .calc-total__value {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--c-forest);
    white-space: nowrap;
  }

  /* ── Azalea included list ── */
  .calc-included-list {
    list-style: none;
    margin: 0;
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .calc-included-list li {
    font-size: 0.9rem;
    color: var(--c-ink);
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    line-height: 1.5;
  }
  .calc-included-group-label {
    font-family: var(--font-sans);
    font-size: 0.75rem !important;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-accent) !important;
    margin-top: var(--space-3) !important;
    padding-bottom: var(--space-2) !important;
    border-bottom: 1px solid #e8e2d9;
    display: block !important;
  }
  .calc-check {
    color: var(--c-forest);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Assisted-only input group ── */
  .calc-group--assisted-only {
    display: none;
  }
  .calc-layout[data-care="assisted"] .calc-group--assisted-only {
    display: block;
  }
  .calc-group__label-note {
    font-weight: 400;
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.7rem;
    color: var(--c-accent);
    opacity: 0.8;
  }

  /* Assisted living items — hidden by default */
  .calc-assisted-item,
  .calc-included-group-label--assisted {
    display: none !important;
  }
  .calc-layout[data-care="assisted"] .calc-assisted-item,
  .calc-layout[data-care="assisted"] .calc-included-group-label--assisted {
    display: flex !important;
  }
  .calc-layout[data-care="assisted"] .calc-included-group-label--assisted {
    display: block !important;
  }

  /* ── CTA block ── */
  .calc-cta {
    padding: var(--space-5) var(--space-6) var(--space-6);
    background: #f0f4ed;
    border-top: 1px solid #d5e0cf;
    text-align: center;
  }
  .calc-cta__text {
    font-size: 0.9rem;
    color: var(--c-ink-soft);
    margin-bottom: var(--space-4);
  }
  .calc-cta .btn { margin: 0 var(--space-2) var(--space-2); }

  /* ── Comparison bars ── */
  .calc-comparison {
    margin-top: var(--space-8);
    background: var(--c-sand);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-7);
  }
  .calc-comparison__inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .calc-bar-wrap {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  @media (max-width: 600px) {
    .calc-bar-wrap { grid-template-columns: 1fr; }
  }
  .calc-bar-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-ink);
  }
  .calc-bar-wrap--avg .calc-bar-label {
    color: var(--c-ink-soft);
    font-weight: 400;
    font-style: italic;
  }
  .calc-bar-track {
    height: 28px;
    background: #ddd5c8;
    border-radius: 4px;
    overflow: hidden;
  }
  .calc-bar-wrap--avg .calc-bar-track {
    height: 20px;
  }
  .calc-bar {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: width 0.4s ease;
  }
  .calc-bar--home { background: var(--c-accent); }
  .calc-bar--avg { background: #b5a898; }
  .calc-bar--azalea { background: var(--c-forest); }
  .calc-bar-amount {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-ink);
    white-space: nowrap;
    min-width: 110px;
    text-align: right;
  }
  .calc-bar-wrap--avg .calc-bar-amount {
    font-weight: 400;
    color: var(--c-ink-soft);
  }
  .calc-comparison__note {
    text-align: center;
    font-size: 0.9rem;
    color: var(--c-ink-soft);
    margin-top: var(--space-4);
    min-height: 1.5em;
    font-style: italic;
  }

  /* ── Disclaimer ── */
  .calc-disclaimer {
    margin-top: var(--space-5);
    font-size: 0.75rem;
    color: var(--c-ink-soft);
    font-style: italic;
    text-align: center;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
</style>

<script>
(function() {
  var RATES = {
    independent: 3500,
    assisted: 5000
  };

  var NATIONAL_AVG_BASE = 3940;      // independent living baseline
  var NATIONAL_AVG_ASSISTED = 8932; // baseline + aide ($4,767) + medical transport ($150) + med mgmt ($75)

  var careSelect = document.getElementById('careLevel');
  var calcLayout = document.querySelector('.calc-layout');
  var azaleaRateEl = document.getElementById('azaleaRate');
  var homeTotalEl = document.getElementById('homeTotal');
  var barHome = document.getElementById('barHome');
  var barAvg = document.getElementById('barAvg');
  var barAzalea = document.getElementById('barAzalea');
  var barHomeAmt = document.getElementById('barHomeAmt');
  var barAzaleaAmt = document.getElementById('barAzaleaAmt');
  var calcNote = document.getElementById('calcNote');
  var avgTotalValue = document.querySelector('.calc-avg-total-value');
  var inputs = document.querySelectorAll('.calc-input');
  var assistedInputs = document.querySelectorAll('.calc-input--assisted');
  var useAvgBtn = document.getElementById('useAverages');

  function formatDollars(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function getHomeTotal() {
    var total = 0;
    inputs.forEach(function(inp) {
      var val = parseFloat(inp.value) || 0;
      if (val > 0) total += val;
    });
    return total;
  }

  function getAzaleaRate() {
    return RATES[careSelect.value] || 0;
  }

  function getNationalAvg() {
    return careSelect.value === 'assisted' ? NATIONAL_AVG_ASSISTED : NATIONAL_AVG_BASE;
  }

  function updateBars(homeTotal, azaleaRate) {
    var natAvg = getNationalAvg();
    var max = Math.max(homeTotal, azaleaRate, natAvg, 1);
    barHome.style.width = (homeTotal / max * 100) + '%';
    barAvg.style.width = (natAvg / max * 100) + '%';
    barAzalea.style.width = (azaleaRate / max * 100) + '%';
    barHomeAmt.textContent = formatDollars(homeTotal) + ' / mo';
    barAzaleaAmt.textContent = formatDollars(azaleaRate) + '+ / mo';
    // Update the avg bar label amount
    var avgAmtEl = barAvg.closest('.calc-bar-wrap') && barAvg.closest('.calc-bar-wrap').querySelector('.calc-bar-amount');
    if (avgAmtEl) avgAmtEl.textContent = formatDollars(natAvg) + ' / mo';
    // Update the avg total row
    if (avgTotalValue) avgTotalValue.textContent = formatDollars(natAvg) + '/mo';

    if (homeTotal > 0) {
      var diff = homeTotal - azaleaRate;
      if (diff > 0) {
        calcNote.textContent = 'At your current home costs, you could save approximately ' + formatDollars(diff) + ' per month at Azalea Estates — plus gain services and peace of mind not counted here.';
      } else if (diff < 0) {
        calcNote.textContent = 'Your estimated home costs are below the starting rate shown. Call us to discuss the full value included in every Azalea Estates rate.';
      } else {
        calcNote.textContent = 'Your home costs are roughly equal to the Azalea Estates starting rate — with far more included.';
      }
    } else {
      calcNote.textContent = 'Enter your monthly home expenses above to see how the numbers compare.';
    }
  }

  function update() {
    var homeTotal = getHomeTotal();
    var azaleaRate = getAzaleaRate();

    homeTotalEl.textContent = formatDollars(homeTotal);
    azaleaRateEl.textContent = formatDollars(azaleaRate) + '+/mo';

    calcLayout.setAttribute('data-care', careSelect.value);
    updateBars(homeTotal, azaleaRate);
  }

  // Fill all fields with national averages
  useAvgBtn.addEventListener('click', function() {
    var isAssisted = careSelect.value === 'assisted';
    inputs.forEach(function(inp) {
      // Skip assisted-only fields if we're in independent mode
      if (inp.classList.contains('calc-input--assisted') && !isAssisted) return;
      var avg = inp.getAttribute('data-avg');
      if (avg) {
        inp.value = avg;
        inp.classList.add('is-avg');
      }
    });
    update();
    // Scroll to comparison
    var comparison = document.getElementById('calcComparison');
    if (comparison) {
      comparison.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // Remove italic styling when user edits a field
  inputs.forEach(function(inp) {
    inp.addEventListener('input', function() {
      inp.classList.remove('is-avg');
      update();
    });
  });

  careSelect.addEventListener('change', function() {
    // When switching back to independent, clear the assisted-only fields
    if (careSelect.value === 'independent') {
      assistedInputs.forEach(function(inp) {
        inp.value = '';
        inp.classList.remove('is-avg');
      });
    }
    update();
  });

  // Init
  update();
})();
</script>
