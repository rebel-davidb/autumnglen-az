---
layout: layouts/base.njk
title: Thank You
description: "Thanks for reaching out to Azalea Estates — a member of our admissions team will be in touch within one business day."
permalink: /contact/thanks/index.html
noindex: true
---

<section class="section">
  <div class="container container--narrow" style="text-align:center; padding-top:var(--space-9); padding-bottom:var(--space-9);">

    <!-- Success icon -->
    <div class="thanks__icon" aria-hidden="true">
      <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="32" cy="32" r="32" fill="#213b14" fill-opacity="0.1"/>
        <circle cx="32" cy="32" r="24" fill="#213b14"/>
        <path d="M20 32l9 9 15-16" stroke="#faf6f1" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <span class="eyebrow" style="display:block; margin-top:var(--space-5);">Message Received</span>
    <h1 style="margin-top:var(--space-3);">Thank you for reaching out.</h1>
    <p class="lead" style="max-width:560px; margin:0 auto var(--space-6);">
      A member of our admissions team will be in touch within one business day. We read every message personally &mdash; and we look forward to helping you and your family.
    </p>

    <!-- Quick-glance reminders -->
    <div class="thanks__reminders">
      <div class="thanks__reminder">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.38 2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <div>
          <strong>Prefer to talk now?</strong>
          <span>Call us at <a href="tel:{{ site.contact.phoneRaw }}">{{ site.contact.phone }}</a><br>Monday&ndash;Friday, 9&thinsp;am&ndash;5&thinsp;pm</span>
        </div>
      </div>
      <div class="thanks__reminder">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div>
          <strong>Come see us</strong>
          <span><a href="{{ site.contact.mapsUrl }}" target="_blank" rel="noopener">{{ site.contact.addressLine1 }}<br>{{ site.contact.addressLine2 }}</a></span>
        </div>
      </div>
      <div class="thanks__reminder">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <div>
          <strong>Check your email</strong>
          <span>Our reply will come from a member of the Azalea Estates team</span>
        </div>
      </div>
    </div>

    <!-- Next steps -->
    <div style="margin-top:var(--space-8);">
      <p style="color:var(--c-muted); margin-bottom:var(--space-4);">While you wait, explore more about Azalea Estates:</p>
      <div style="display:flex; gap:var(--space-3); justify-content:center; flex-wrap:wrap;">
        <a href="/schedule-a-tour/" class="btn btn--primary">Schedule a Tour</a>
        <a href="/gallery/" class="btn btn--outline">Photo Tour</a>
        <a href="/living-options/" class="btn btn--ghost">Living Options</a>
      </div>
    </div>

  </div>
</section>
