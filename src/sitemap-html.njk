      {# ── RIGHT: Contact form ── #}
      <div class="sitemap-panel sitemap-panel--form">
        <div class="sitemap-form-header">
          <span class="eyebrow">Get in Touch</span>
          <h2 class="sitemap-form-title">Can&rsquo;t find what you&rsquo;re looking for?</h2>
          <p class="sitemap-form-sub">Our team is happy to help. Send us a message and we&rsquo;ll get back to you within one business day.</p>
        </div>

        <form
          name="contact"
          method="POST"
          action="/contact/thanks/"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="form"
        >
          <input type="hidden" name="form-name" value="contact">
          <p style="display:none;"><label>Don&rsquo;t fill this out if you&rsquo;re human: <input name="bot-field"></label></p>

          <div class="form-row">
            <div class="form-field">
              <label for="sm_first_name">First Name *</label>
              <input type="text" id="sm_first_name" name="first_name" required autocomplete="given-name">
            </div>
            <div class="form-field">
              <label for="sm_last_name">Last Name *</label>
              <input type="text" id="sm_last_name" name="last_name" required autocomplete="family-name">
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="sm_email">Email *</label>
              <input type="email" id="sm_email" name="email" required autocomplete="email">
            </div>
            <div class="form-field">
              <label for="sm_phone">Phone</label>
              <input type="tel" id="sm_phone" name="phone" autocomplete="tel">
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="sm_relation">This inquiry is for&hellip;</label>
              <select id="sm_relation" name="relation">
                <option value="self">Myself</option>
                <option value="parent">A parent</option>
                <option value="spouse">A spouse</option>
                <option value="relative">Another relative</option>
                <option value="professional">A client (I&rsquo;m a professional)</option>
              </select>
            </div>
            <div class="form-field">
              <label for="sm_interest">Primary interest</label>
              <select id="sm_interest" name="interest">
                <option value="independent">Independent Living</option>
                <option value="assisted">Assisted Living</option>
                <option value="respite">Respite / Short-term Care</option>
                <option value="tour">Scheduling a tour</option>
                <option value="other">Something else</option>
              </select>
            </div>
          </div>

          <div class="form-field">
            <label for="sm_message">How can we help?</label>
            <textarea id="sm_message" name="message" placeholder="Tell us a bit about timeline, needs, or any questions you have&hellip;"></textarea>
          </div>

          <label class="form-consent">
            <input type="checkbox" name="consent" required>
            <span>I&rsquo;d like to be contacted about Azalea Estates. I understand I can opt out anytime.</span>
          </label>

          {# Attribution fields — populated by JS on page load #}
          <input type="hidden" name="cf_utm_source">
          <input type="hidden" name="cf_utm_medium">
          <input type="hidden" name="cf_utm_campaign">
          <input type="hidden" name="cf_utm_content">
          <input type="hidden" name="cf_utm_term">
          <input type="hidden" name="cf_landing_page">
          <input type="hidden" name="cf_referrer">
          <input type="hidden" name="cf_form_page">

          <button type="submit" class="btn btn--primary">Send Message</button>
        </form>
      </div>

