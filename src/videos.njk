{# ── VideoObject structured data — enables Google video rich results ─────── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Azalea Estates Videos",
  "url": "{{ site.url }}/videos/",
  "itemListElement": [
    {% for video in videos %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": {
        "@type": "VideoObject",
        "name": "{{ video.title }}",
        "description": "{{ video.desc }}",
        "thumbnailUrl": "https://img.youtube.com/vi/{{ video.id }}/maxresdefault.jpg",
        "uploadDate": "{{ video.uploadDate }}",
        "embedUrl": "https://www.youtube.com/embed/{{ video.id }}",
        "contentUrl": "https://www.youtube.com/watch?v={{ video.id }}",
        "publisher": {
          "@type": "Organization",
          "name": "{{ site.name }}",
          "logo": {
            "@type": "ImageObject",
            "url": "{{ site.url }}/assets/images/logo.png"
          }
        }
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<!-- FEATURED VIDEOS -->
<section class="section">
  <div class="container">
    <div class="section-heading section-heading--left reveal">
      <span class="eyebrow">Start Here</span>
      <h2>The best introduction to our community.</h2>
    </div>
    <div class="feature-grid">
      {% for video in videos %}
        {% if video.featured %}
        <article class="video-card reveal">
          <button class="video-card__thumb" data-video-id="{{ video.id }}" aria-label="Play: {{ video.title }}">
            <img src="https://img.youtube.com/vi/{{ video.id }}/maxresdefault.jpg" alt="{{ video.title }}" loading="lazy">
            <span class="video-card__play" aria-hidden="true"></span>
          </button>
          <div class="video-card__body">
            <h3>{{ video.title }}</h3>
            <p>{{ video.desc }}</p>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ALL VIDEOS GRID -->
<section class="section section--cream">
  <div class="container">
    <div class="section-heading section-heading--left reveal">
      <span class="eyebrow">Full Video Library</span>
      <h2>More to explore.</h2>
    </div>
    <div class="videos-grid">
      {% for video in videos %}
        {% if not video.featured %}
        <article class="video-card video-card--compact reveal">
          <button class="video-card__thumb" data-video-id="{{ video.id }}" aria-label="Play: {{ video.title }}">
            <img src="https://img.youtube.com/vi/{{ video.id }}/maxresdefault.jpg" alt="{{ video.title }}" loading="lazy">
            <span class="video-card__play" aria-hidden="true"></span>
          </button>
          <div class="video-card__body">
            <h3>{{ video.title }}</h3>
            <p>{{ video.desc }}</p>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{# ── Video modal ───────────────────────────────────────────────────────────── #}
<div class="video-modal" id="videoModal" role="dialog" aria-modal="true" aria-label="Video player" hidden>
  <div class="video-modal__backdrop" id="videoModalBackdrop"></div>
  <div class="video-modal__panel">
    <button class="video-modal__close" id="videoModalClose" aria-label="Close video">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
    </button>
    <div class="video-modal__stage">
      <iframe id="videoModalFrame" frameborder="0"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen></iframe>
    </div>
  </div>
</div>

