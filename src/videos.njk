<!-- FEATURED VIDEOS -->
<section class="section">
  <div class="container">
    <div class="section-heading section-heading--left reveal">
      <span class="eyebrow">Start Here</span>
      <h2>The best introduction to our community.</h2>
    </div>
    <div class="feature-grid">
      {% for video in videos %}
        {% if video.featured %}
        <article class="video-card reveal">
          <div class="video-card__embed">
            <iframe
              src="https://www.youtube.com/embed/{{ video.id }}"
              title="{{ video.title }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy">
            </iframe>
          </div>
          <div class="video-card__body">
            <h3>{{ video.title }}</h3>
            <p>{{ video.desc }}</p>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ALL VIDEOS GRID -->
<section class="section section--cream">
  <div class="container">
    <div class="section-heading section-heading--left reveal">
      <span class="eyebrow">Full Video Library</span>
      <h2>More to explore.</h2>
    </div>
    <div class="videos-grid">
      {% for video in videos %}
        {% if not video.featured %}
        <article class="video-card video-card--compact reveal">
          <div class="video-card__embed video-card__embed--compact">
            <iframe
              src="https://www.youtube.com/embed/{{ video.id }}"
              title="{{ video.title }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy">
            </iframe>
          </div>
          <div class="video-card__body">
            <h3>{{ video.title }}</h3>
            <p>{{ video.desc }}</p>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

