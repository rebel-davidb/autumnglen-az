{# Page-scoped style override — ensures the flywheel two-column grid
   isn't clobbered by any browser-extension stylesheets in local dev #}
<style>
  /* Grid layout — overrides browser-extension stylesheet in local dev */
  .container .closing-gaps-layout {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 3rem !important;
    align-items: start !important;
    margin-top: 2.5rem !important;
  }
  .closing-gaps-steps {
    display: flex !important;
    flex-direction: column !important;
    gap: 1.25rem !important;
  }

  /* Step cards */
  .step-card {
    display: flex !important;
    gap: 1rem !important;
    background: #fff !important;
    border: 1px solid #e1d7c8 !important;
    border-radius: 8px !important;
    padding: 1.5rem !important;
    cursor: default !important;
    transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
  }
  .step-card:hover,
  .step-card.is-active {
    border-color: #b08a3a !important;
    box-shadow: 0 2px 12px rgba(176,138,58,0.18) !important;
  }
  .step-card__num {
    flex-shrink: 0 !important;
    width: 2.5rem !important;
    height: 2.5rem !important;
    min-width: 2.5rem !important;
    border-radius: 50% !important;
    background: #213b14 !important;
    color: #faf6f1 !important;
    font-weight: 700 !important;
    font-size: 1rem !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin-top: 0.15rem !important;
  }
  .step-card.is-active .step-card__num,
  .step-card:hover .step-card__num {
    background: #b08a3a !important;
  }
  .step-card__body { flex: 1 !important; }
  .step-card__body h3 {
    font-size: 1rem !important;
    font-weight: 700 !important;
    margin: 0 0 0.4rem !important;
    color: #213b14 !important;
  }
  .step-card__body p {
    margin: 0 !important;
    font-size: 0.95rem !important;
    line-height: 1.65 !important;
    color: #2a2623 !important;
  }

  /* Flywheel sticky positioning (JS-driven — position:sticky broken by overflow-x:hidden on body) */
  .closing-gaps-flywheel.is-sticky {
    position: fixed !important;
    top: 88px; /* JS overrides this inline when riding section bottom */
    z-index: 10 !important;
    transform: none !important;
  }
  .closing-gaps-flywheel-ghost {
    visibility: hidden !important;
    pointer-events: none !important;
  }

  /* Flywheel active node */
  .flywheel-node { transition: transform 0.3s ease !important; }
  .flywheel-node circle.node-fill { transition: fill 0.3s ease !important; }
  .flywheel-node circle.node-ring {
    fill: none !important;
    stroke: var(--c-accent) !important;
    stroke-width: 2 !important;
    opacity: 0 !important;
    transition: opacity 0.3s ease !important;
  }
  .flywheel-node.is-active circle.node-fill { fill: #b08a3a !important; }
  .flywheel-node.is-active circle.node-ring { opacity: 1 !important; }
  #flywheel-node-1.is-active { transform: scale(1.07) !important; transform-origin: 230px 65px !important; }
  #flywheel-node-2.is-active { transform: scale(1.07) !important; transform-origin: 387px 177px !important; }
  #flywheel-node-3.is-active { transform: scale(1.07) !important; transform-origin: 328px 365px !important; }
  #flywheel-node-4.is-active { transform: scale(1.07) !important; transform-origin: 132px 365px !important; }
  #flywheel-node-5.is-active { transform: scale(1.07) !important; transform-origin: 73px 177px !important; }

  @media (max-width: 780px) {
    .container .closing-gaps-layout {
      grid-template-columns: 1fr !important;
    }
    .closing-gaps-flywheel {
      order: -1 !important;
      max-width: 340px !important;
      margin: 0 auto !important;
    }
  }
</style>

<!-- INTRO: AZALEA CARE MODEL -->
<section class="section">
  <div class="container">
    <div class="intro-split">
      <div class="intro-split__body reveal">
        <span class="eyebrow">Azalea Care</span>
        <h2>Our Proactive, Comprehensive Care Model for Enhancing Your Life.</h2>
        <p class="lead">At the heart of Azalea Estates&rsquo; approach to resident care is the goal of enhancing quality of life and significantly reducing preventable emergency room visits and hospitalizations, what the industry calls &ldquo;value-based care.&rdquo; We call our approach <strong>Azalea Care</strong>.</p>
        <p>Azalea Care is designed to be proactive and to simplify the often-complicated process of caring for a loved one. By collaborating closely with families and healthcare providers, we aim to improve the overall health and wellness of our residents, providing a stark contrast to the challenges of coordinating care independently.</p>
        <p>Our Resident Care Director, a licensed nurse, works directly with each resident, their family, and their physicians to coordinate every aspect of their care. From preventive wellness visits to managing chronic conditions to organizing care transitions, we handle the complexity so families don&rsquo;t have to.</p>
      </div>
      <div class="intro-split__media reveal">
        <img src="{{ images.treadmillSupport }}" alt="Azalea Estates staff member guiding a resident one-on-one" loading="lazy">
      </div>
    </div>
  </div>
</section>

<!-- HOW AZALEA CARE WORKS: STEP BY STEP -->
<section class="section section--cream">
  <div class="container">
    <div class="section-heading reveal">
      <span class="eyebrow">How Azalea Care Works</span>
      <h2>Closing Gaps in Care, Step by Step.</h2>
    </div>
    <div class="closing-gaps-layout">

      <!-- Steps list -->
      <div class="closing-gaps-steps reveal">
        <div class="step-card" data-step="1">
          <div class="step-card__num">1</div>
          <div class="step-card__body">
            <h3>Health Assessment</h3>
            <p>Every resident receives a thorough health assessment with our Resident Care Director (a registered nurse or LPN) before and upon move-in.</p>
          </div>
        </div>
        <div class="step-card" data-step="2">
          <div class="step-card__num">2</div>
          <div class="step-card__body">
            <h3>Resident Care Director</h3>
            <p>Our on-site Care Director coordinates all aspects of care, equipped with up-to-date technology to communicate with primary providers and specialists.</p>
          </div>
        </div>
        <div class="step-card" data-step="3">
          <div class="step-card__num">3</div>
          <div class="step-card__body">
            <h3>Personalized Care Plan</h3>
            <p>A comprehensive care plan is created based on each resident&rsquo;s needs, values, goals, and preferences, including their choice of on-site or outside primary care.</p>
          </div>
        </div>
        <div class="step-card" data-step="4">
          <div class="step-card__num">4</div>
          <div class="step-card__body">
            <h3>Patient &amp; Healthcare Team</h3>
            <p>The Care Director works hand-in-hand with the resident&rsquo;s full healthcare team, coordinating referrals, transitions, and follow-up visits.</p>
          </div>
        </div>
        <div class="step-card" data-step="5">
          <div class="step-card__num">5</div>
          <div class="step-card__body">
            <h3>Ongoing Monitoring &amp; Record</h3>
            <p>Health is monitored continuously. The Care Director triages urgent needs, reconciles medications, and keeps a complete electronic health record.</p>
          </div>
        </div>
      </div>

      <!-- Flywheel SVG -->
      <!-- Node centers (r=165 from 230,230):
           1 (top):         230, 65
           2 (upper-right): 387, 177
           3 (lower-right): 328, 365
           4 (lower-left):  132, 365
           5 (upper-left):   73, 177  -->
      <div class="closing-gaps-flywheel" aria-hidden="true">
        <svg viewBox="0 0 460 460" xmlns="http://www.w3.org/2000/svg" overflow="visible" role="img" aria-label="Azalea Care cycle diagram showing five connected steps">
          <title>Azalea Care Flywheel</title>

          <defs>
            <marker id="arrow" markerWidth="14" markerHeight="14" refX="7" refY="7" orient="auto" markerUnits="userSpaceOnUse">
              <path d="M1,1 L13,7 L1,13 Z" style="fill: var(--c-accent)"/>
            </marker>
          </defs>

          <!--
            Node centers (r=62):  1=(230,65)  2=(387,177)  3=(328,365)  4=(132,365)  5=(73,177)
            Each arrow starts ~68px from source center and ends ~68px from destination center,
            so arrowheads land clearly in the gap between circles.
          -->

          <!-- Arrow 1→2: arc outward upper-right -->
          <path d="M 289,107 Q 355,56 328,135" fill="none" stroke-width="3.5" marker-end="url(#arrow)" style="stroke: var(--c-accent)"/>

          <!-- Arrow 2→3: arc outward right -->
          <path d="M 365,246 Q 434,295 350,296" fill="none" stroke-width="3.5" marker-end="url(#arrow)" style="stroke: var(--c-accent)"/>

          <!-- Arrow 3→4: arc outward bottom -->
          <path d="M 276,418 Q 230,446 184,418" fill="none" stroke-width="3.5" marker-end="url(#arrow)" style="stroke: var(--c-accent)"/>

          <!-- Arrow 4→5: arc outward left -->
          <path d="M 110,296 Q 26,295 95,246" fill="none" stroke-width="3.5" marker-end="url(#arrow)" style="stroke: var(--c-accent)"/>

          <!-- Arrow 5→1: arc outward upper-left -->
          <path d="M 132,135 Q 105,56 171,107" fill="none" stroke-width="3.5" marker-end="url(#arrow)" style="stroke: var(--c-accent)"/>

          <!-- Node 1: Health Assessment (top) -->
          <g class="flywheel-node" id="flywheel-node-1">
            <circle class="node-ring" cx="230" cy="65" r="68"/>
            <circle class="node-fill" cx="230" cy="65" r="62" fill="#213b14"/>
            <text x="230" y="49" text-anchor="middle" fill="#f5f0e8" font-size="12.5" font-weight="700" font-family="Georgia,serif">1.</text>
            <text x="230" y="65" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Health</text>
            <text x="230" y="80" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Assessment</text>
          </g>

          <!-- Node 2: Resident Care Director (upper-right) -->
          <g class="flywheel-node" id="flywheel-node-2">
            <circle class="node-ring" cx="387" cy="177" r="68"/>
            <circle class="node-fill" cx="387" cy="177" r="62" fill="#213b14"/>
            <text x="387" y="161" text-anchor="middle" fill="#f5f0e8" font-size="12.5" font-weight="700" font-family="Georgia,serif">2.</text>
            <text x="387" y="177" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Resident Care</text>
            <text x="387" y="192" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Director</text>
          </g>

          <!-- Node 3: Personalized Care Plan (lower-right) -->
          <g class="flywheel-node" id="flywheel-node-3">
            <circle class="node-ring" cx="328" cy="365" r="68"/>
            <circle class="node-fill" cx="328" cy="365" r="62" fill="#213b14"/>
            <text x="328" y="345" text-anchor="middle" fill="#f5f0e8" font-size="12.5" font-weight="700" font-family="Georgia,serif">3.</text>
            <text x="328" y="362" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Personalized</text>
            <text x="328" y="377" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Care Plan</text>
          </g>

          <!-- Node 4: Patient & Healthcare Team (lower-left) -->
          <g class="flywheel-node" id="flywheel-node-4">
            <circle class="node-ring" cx="132" cy="365" r="68"/>
            <circle class="node-fill" cx="132" cy="365" r="62" fill="#213b14"/>
            <text x="132" y="345" text-anchor="middle" fill="#f5f0e8" font-size="12.5" font-weight="700" font-family="Georgia,serif">4.</text>
            <text x="132" y="362" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Patient &amp;</text>
            <text x="132" y="377" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Healthcare Team</text>
          </g>

          <!-- Node 5: Ongoing Monitoring (upper-left) -->
          <g class="flywheel-node" id="flywheel-node-5">
            <circle class="node-ring" cx="73" cy="177" r="68"/>
            <circle class="node-fill" cx="73" cy="177" r="62" fill="#213b14"/>
            <text x="73" y="161" text-anchor="middle" fill="#f5f0e8" font-size="12.5" font-weight="700" font-family="Georgia,serif">5.</text>
            <text x="73" y="177" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Ongoing</text>
            <text x="73" y="192" text-anchor="middle" fill="#f5f0e8" font-size="11.5" font-family="Georgia,serif">Monitoring</text>
          </g>

          <!-- Center label -->
          <text x="230" y="215" text-anchor="middle" fill="#213b14" font-size="12" font-weight="700" font-family="Georgia,serif">Azalea</text>
          <text x="230" y="232" text-anchor="middle" fill="#213b14" font-size="12" font-weight="700" font-family="Georgia,serif">Care</text>
          <text x="230" y="248" text-anchor="middle" fill="#213b14" font-size="11" font-family="Georgia,serif">Cycle</text>
        </svg>
      </div>

    </div>
  </div>
</section>

<!-- APPROACH SECTION -->
<section class="section">
  <div class="container">
    <div class="section-heading reveal">
      <span class="eyebrow">Azalea Care: Our Approach</span>
      <h2>Coordinated, compassionate care at every level.</h2>
      <p>Each Azalea Estates resident benefits from a dedicated Resident Care Director who actively assists in managing their daily health needs. Our care team partners with outside healthcare professionals to support residents through transitions, ensure seamless communication between providers, reconcile medications, and schedule follow-up visits.</p>
    </div>
    <div class="pillars">
      <div class="pillar reveal">
        <h3>Assisted &amp; Memory Care</h3>
        <p>The Resident Care Director creates and implements individualized care plans tailored to each resident&rsquo;s health needs, values, and goals.</p>
      </div>
      <div class="pillar reveal">
        <h3>Independent Living</h3>
        <p>Our Care Director and team provide proactive support and advocacy, available when you need us, respectful of your independence always.</p>
      </div>
      <div class="pillar reveal">
        <h3>Family Partnership</h3>
        <p>We keep loved ones informed and included in every care decision, with regular communication and an open-door approach to family involvement.</p>
      </div>
      <div class="pillar reveal">
        <h3>Provider Coordination</h3>
        <p>We work hand-in-hand with your existing physicians, specialists, and pharmacy to eliminate gaps and redundancies in care.</p>
      </div>
    </div>
  </div>
</section>

