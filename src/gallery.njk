---
layout: layouts/page.njk
title: Photo Tour
metaTitle: "Virtual Tour & Photo Gallery | Azalea Estates Fayetteville, GA"
description: "Take an interactive 360° virtual tour of Azalea Estates in Fayetteville, GA, then browse our full photo gallery — campus, suites, dining, pool, and community life."
eyebrow: A Glimpse of Life Here
pageIntro: "Walk through our campus in 360° — then browse photos of the spaces and people that make Azalea Estates home."
eleventyComputed:
  pageHero: "{{ images.communityGarden }}"
permalink: /gallery/
---

<!-- VIRTUAL TOUR -->
<section class="section">
  <div class="container">
    <div class="section-heading reveal">
      <span class="eyebrow">Interactive 360&deg; Tour</span>
      <h2>Walk through our campus from anywhere.</h2>
      <p>Use your mouse, trackpad, or finger to look around every room before you ever set foot on campus. Works on phone, tablet, and desktop.</p>
    </div>
    <div class="virtual-tour reveal">
      <iframe
        src="https://tourmkr.com/F1NLCFWPFI/32620506p&amp;194.98h&amp;88.35t"
        title="Azalea Estates of Fayetteville — Interactive 360&deg; Virtual Tour"
        allowfullscreen
        loading="lazy">
      </iframe>
    </div>
    <p class="virtual-tour__hint">
      Drag to look around &nbsp;&middot;&nbsp; Scroll or pinch to zoom &nbsp;&middot;&nbsp; Click hotspots to move between rooms
    </p>
  </div>
</section>

<!-- PHOTO GALLERY -->
<section class="section section--cream">
  <div class="container">
    <div class="section-heading section-heading--left reveal">
      <span class="eyebrow">Photo Gallery</span>
      <h2>Campus, suites, dining, and daily life.</h2>
    </div>
    <div class="gallery-grid">
      {% for photo in images.gallery %}
        <div class="gallery-item reveal" data-full="{{ photo.src }}" role="button" tabindex="0" aria-label="{{ photo.alt }}">
          <img src="{{ photo.src }}" alt="{{ photo.alt }}" loading="lazy">
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% set related = [
  { url: '/floor-plans/', eyebrow: 'Your Private Suite', title: 'Floor Plans',
    desc: "You've seen the campus — now explore the specific suite layouts, sizes, and PDF drawings.",
    cta: 'View floor plans' },
  { url: '/living-options/', eyebrow: 'Care Levels', title: 'Living Options',
    desc: 'Ready to think about care options? Compare independent, assisted, and respite care.',
    cta: 'Explore care levels' },
  { url: '/schedule-a-tour/', eyebrow: 'Nothing Beats In Person', title: 'Schedule a Private Tour',
    desc: "You've seen the photos. Come walk through it. Tours include a campus walk and complimentary lunch.",
    cta: 'Schedule your tour' }
] %}
{% include "partials/related.njk" %}

<section class="cta-panel">
  <div class="container">
    <div class="cta-panel__grid">
      <div>
        <span class="eyebrow" style="color: var(--c-accent-soft);">Nothing beats seeing it in person</span>
        <h2>Schedule a private tour.</h2>
        <p>A virtual tour shows you the spaces. A visit lets you feel whether Azalea Estates is the right home. Meet the residents, taste the food, and talk with our team.</p>
      </div>
      <div class="cta-panel__btns">
        <a href="/schedule-a-tour/" class="btn btn--primary">Schedule a Tour</a>
      </div>
    </div>
  </div>
</section>
