      <div class="stats-bar__stat">
        <span class="stats-bar__num">79</span>
        <span class="stats-bar__label">Private Suites</span>
      </div>
      <div class="stats-bar__stat">
        <span class="stats-bar__num">10</span>
        <span class="stats-bar__label">Acre Campus</span>
      </div>
      <div class="stats-bar__stat">
        <span class="stats-bar__num">24/7</span>
        <span class="stats-bar__label">Caring Staff</span>
      </div>
    </div>
  </div>
</section>

<!-- INTRO SPLIT -->
<section class="section">
  <div class="container">
    <div class="intro-split">
      <div class="intro-split__media reveal">
        <img src="{{ images.residentsLaughing }}" alt="Residents sharing a warm moment together" loading="lazy">
      </div>
      <div class="intro-split__body reveal">
        <span class="eyebrow">About Azalea Estates</span>
        <h2>Built around the people who live here.</h2>
        <p class="lead">Azalea Estates sits on a quiet 10-acre campus just off Highway 54 in the heart of Fayetteville, Georgia. Same owners, same thoughtful management &mdash; for more than three decades.</p>
        <p>Every detail, from the architecture of our one-story neighborhood to the rhythm of our daily activities, is shaped by what residents tell us matters most: independence, connection, and a genuine feeling of home.</p>
        <a href="/about/" class="btn btn--ghost">More about our community</a>
        <div class="signature">
          <div class="signature__avatar">{{ icon('heart', 22) }}</div>
          <div class="signature__text">
            <strong>Family-owned since 1993</strong>
            Proudly serving Fayette County &amp; Peachtree City
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

