---
layout: layouts/base.njk
title: Blog
metaTitle: "Senior Living Blog — Tips, Resources & Community Life | Azalea Estates"
description: "Practical advice on assisted living, healthy aging, caregiver resources, dining, and community life from the team at Azalea Estates of Fayetteville, GA."
permalink: /blog/
pageHero: "/assets/images/two-women-reading.jpg"
---

{% from "partials/icons.njk" import icon %}

{# ── Sort posts newest-first, derive the featured post ─────────────────── #}
{%- set sorted = posts.all | sort(attribute="date") | reverse -%}
{%- set featured = null -%}
{%- for p in sorted -%}
  {%- if p.featured and not featured -%}{%- set featured = p -%}{%- endif -%}
{%- endfor -%}
{%- if not featured and sorted.length -%}{%- set featured = sorted[0] -%}{%- endif -%}

{# ── Structured data: Blog ─────────────────────────────────────────────── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "{{ site.url }}/blog/#blog",
  "name": "{{ site.shortName }} Blog",
  "url": "{{ site.url }}/blog/",
  "description": "{{ description }}",
  "publisher": { "@type": "Organization", "name": "{{ site.name }}", "logo": "{{ site.url }}/assets/images/logo.png" },
  "blogPost": [
    {%- for p in sorted %}
    {
      "@type": "BlogPosting",
      "headline": {{ p.title | dump | safe }},
      "url": "{{ site.url }}/blog/{{ p.slug }}/",
      "datePublished": "{{ p.date }}",
      "image": "{{ site.url }}{{ p.image }}",
      "author": { "@type": "Person", "name": {{ p.author | dump | safe }} },
      "articleSection": {{ p.category | dump | safe }}
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>

<!-- ════════════════════════════════════════════════════════════════════
     BLOG HERO
     ════════════════════════════════════════════════════════════════════ -->
<section class="blog-hero">
  <div class="container blog-hero__inner">
    <p class="crumbs"><a href="/">Home</a> <span>/</span> <span>Blog</span></p>
    <span class="eyebrow">From Our Community</span>
    <h1>The Azalea Estates Blog</h1>
    <p class="lead">Practical, warm guidance on assisted living, healthy aging, caregiving, dining, and the life we share at Azalea Estates of Fayetteville.</p>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════════════
     FEATURED POST
     ════════════════════════════════════════════════════════════════════ -->
{% if featured %}
<section class="section section--cream blog-featured-section" aria-labelledby="blog-featured-heading">
  <div class="container">
    <span class="eyebrow" id="blog-featured-heading">Featured</span>
    <a href="/blog/{{ featured.slug }}/" class="blog-featured reveal">
      <div class="blog-featured__media">
        <img src="{{ featured.image }}" alt="{{ featured.imageAlt }}" loading="eager" decoding="async" width="800" height="520">
      </div>
      <div class="blog-featured__body">
        <span class="blog-tag">{{ featured.category }}</span>
        <h2>{{ featured.title }}</h2>
        <p class="blog-featured__excerpt">{{ featured.excerpt }}</p>
        <div class="blog-meta">
          <span class="blog-meta__author">{{ featured.author }}</span>
          <span class="blog-meta__dot" aria-hidden="true">·</span>
          <time datetime="{{ featured.date }}">{{ featured.date | readableDate }}</time>
          <span class="blog-meta__dot" aria-hidden="true">·</span>
          <span>{{ featured.readTime }} min read</span>
        </div>
        <span class="blog-featured__cta">Read article <span aria-hidden="true">→</span></span>
      </div>
    </a>
  </div>
</section>
{% endif %}

<!-- ════════════════════════════════════════════════════════════════════
     SEARCH + CATEGORY FILTERS + POST GRID
     ════════════════════════════════════════════════════════════════════ -->
<section class="section" aria-labelledby="blog-all-heading">
  <div class="container">

    <div class="section-header reveal">
      <span class="eyebrow">All Articles</span>
      <h2 id="blog-all-heading">Browse the blog</h2>
    </div>

    {# ── Controls: search + category chips ── #}
    <div class="blog-controls reveal" data-blog-controls>
      <div class="blog-search">
        <span class="blog-search__icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <label for="blogSearch" class="sr-only">Search articles</label>
        <input
          type="search"
          id="blogSearch"
          class="blog-search__input"
          placeholder="Search articles…"
          autocomplete="off"
          data-blog-search>
        <button type="button" class="blog-search__clear" data-blog-search-clear hidden aria-label="Clear search">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </button>
      </div>

      <div class="blog-filters" role="group" aria-label="Filter by category">
        <button type="button" class="blog-chip is-active" data-blog-filter="all" aria-pressed="true">All</button>
        {% for cat in posts.categories %}
        <button type="button" class="blog-chip" data-blog-filter="{{ cat }}" aria-pressed="false">{{ cat }}</button>
        {% endfor %}
      </div>
    </div>

    {# ── Result count + empty state ── #}
    <p class="blog-result-count" data-blog-count aria-live="polite"></p>

    {# ── Post grid ── #}
    <div class="blog-grid" data-blog-grid>
      {% for p in sorted %}
      <article
        class="blog-card reveal"
        data-blog-post
        data-category="{{ p.category }}"
        data-search="{{ (p.title ~ ' ' ~ p.excerpt ~ ' ' ~ p.category ~ ' ' ~ p.author) | lower }}">
        <a href="/blog/{{ p.slug }}/" class="blog-card__media" tabindex="-1" aria-hidden="true">
          <img src="{{ p.image }}" alt="{{ p.imageAlt }}" loading="lazy" decoding="async" width="600" height="400">
          <span class="blog-tag blog-tag--on-image">{{ p.category }}</span>
        </a>
        <div class="blog-card__body">
          <h3 class="blog-card__title"><a href="/blog/{{ p.slug }}/">{{ p.title }}</a></h3>
          <p class="blog-card__excerpt">{{ p.excerpt }}</p>
          <div class="blog-meta">
            <span class="blog-meta__author">{{ p.author }}</span>
            <span class="blog-meta__dot" aria-hidden="true">·</span>
            <time datetime="{{ p.date }}">{{ p.date | readableDate }}</time>
            <span class="blog-meta__dot" aria-hidden="true">·</span>
            <span>{{ p.readTime }} min</span>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    {# ── Empty state (shown by JS when no matches) ── #}
    <div class="blog-empty" data-blog-empty hidden>
      <p><strong>No articles found.</strong></p>
      <p>Try a different search term or clear the filters.</p>
      <button type="button" class="btn btn--outline btn--sm" data-blog-reset>Reset filters</button>
    </div>

  </div>
</section>

<!-- ════════════════════════════════════════════════════════════════════
     BOTTOM CTA
     ════════════════════════════════════════════════════════════════════ -->
<section class="section section--ink" aria-labelledby="blog-cta-heading">
  <div class="container" style="text-align:center; max-width:680px;">
    <span class="eyebrow" style="color:var(--c-accent-soft);">Have a Question We Haven't Covered?</span>
    <h2 id="blog-cta-heading" style="color:var(--c-cream);">We're happy to talk it through.</h2>
    <p style="color:rgba(250,246,241,.85); margin-bottom:var(--space-6);">Our admissions team can answer anything about care, cost, or daily life — no pressure, no obligation. Or come see it for yourself with a private tour.</p>
    <a href="/schedule-a-tour/" class="btn btn--primary">Schedule a Private Tour</a>
  </div>
</section>
