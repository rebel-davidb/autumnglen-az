---
pagination:
  data: posts.all
  size: 1
  alias: post
layout: layouts/base.njk
eleventyComputed:
  title: "{{ post.title }}"
  metaTitle: "{{ post.title }} | Azalea Estates Blog"
  description: "{{ post.excerpt }}"
  permalink: "/blog/{{ post.slug }}/"
  ogImage: "{{ post.image }}"
  pageHero: "{{ post.image }}"
---

{% from "partials/icons.njk" import icon %}

{# ── Related posts: same category first, then fill with most recent ────── #}
{%- set sorted = posts.all | sort(attribute="date") | reverse -%}
{%- set related = [] -%}
{%- for p in sorted -%}
  {%- if p.slug != post.slug and p.category == post.category and related.length < 3 -%}
    {%- set related = related.concat([p]) -%}
  {%- endif -%}
{%- endfor -%}
{%- for p in sorted -%}
  {%- if p.slug != post.slug and related.length < 3 and p not in related -%}
    {%- set related = related.concat([p]) -%}
  {%- endif -%}
{%- endfor -%}

{# ── Structured data: BlogPosting ──────────────────────────────────────── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ post.title | dump | safe }},
  "description": {{ post.excerpt | dump | safe }},
  "image": "{{ site.url }}{{ post.image }}",
  "datePublished": "{{ post.date }}",
  "dateModified": "{{ post.date }}",
  "author": { "@type": "Person", "name": {{ post.author | dump | safe }}{% if post.authorRole %}, "jobTitle": {{ post.authorRole | dump | safe }}{% endif %} },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "logo": { "@type": "ImageObject", "url": "{{ site.url }}/assets/images/logo.png" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ site.url }}/blog/{{ post.slug }}/" },
  "articleSection": {{ post.category | dump | safe }},
  "url": "{{ site.url }}/blog/{{ post.slug }}/"
}
</script>

<!-- ════════════════════════════════════════════════════════════════════
     ARTICLE HERO
     ════════════════════════════════════════════════════════════════════ -->
<article class="blogpost">

  <header class="blogpost-hero">
    <div class="container blogpost-hero__inner">
      <p class="crumbs">
        <a href="/">Home</a> <span>/</span>
        <a href="/blog/">Blog</a> <span>/</span>
        <span>{{ post.title }}</span>
      </p>
      <a href="/blog/?category={{ post.category | urlencode }}" class="blog-tag">{{ post.category }}</a>
      <h1>{{ post.title }}</h1>
      <p class="blogpost-hero__excerpt">{{ post.excerpt }}</p>
      <div class="blog-meta blog-meta--hero">
        <span class="blog-meta__author">{{ post.author }}{% if post.authorRole %}<span class="blog-meta__role">, {{ post.authorRole }}</span>{% endif %}</span>
        <span class="blog-meta__dot" aria-hidden="true">·</span>
        <time datetime="{{ post.date }}">{{ post.date | readableDate }}</time>
        <span class="blog-meta__dot" aria-hidden="true">·</span>
        <span>{{ post.readTime }} min read</span>
      </div>
    </div>
  </header>

  <div class="blogpost-figure container">
    <img src="{{ post.image }}" alt="{{ post.imageAlt }}" loading="eager" decoding="async" width="1100" height="620">
  </div>

  <!-- ── BODY + SHARE ──────────────────────────────────────────────────── -->
  <div class="container blogpost-layout">

    <div class="blogpost-body prose">
      {{ post.body | safe }}

      {# Author card #}
      <div class="blogpost-author">
        <div class="blogpost-author__avatar" aria-hidden="true">{{ post.author[0] }}</div>
        <div>
          <strong>{{ post.author }}</strong>
          {% if post.authorRole %}<span class="blogpost-author__role">{{ post.authorRole }}</span>{% endif %}
          <p>Written by the Azalea Estates team to help families navigate senior living with confidence.</p>
        </div>
      </div>
    </div>

    {# Share rail #}
    <aside class="blogpost-share" aria-label="Share this article">
      <span class="blogpost-share__label">Share</span>
      <a class="blogpost-share__btn" aria-label="Share on Facebook" target="_blank" rel="noopener"
         href="https://www.facebook.com/sharer/sharer.php?u={{ site.url }}/blog/{{ post.slug }}/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 10-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0022 12z"/></svg>
      </a>
      <a class="blogpost-share__btn" aria-label="Share by email" target="_blank" rel="noopener"
         href="mailto:?subject={{ post.title | urlencode }}&body=Thought you might find this helpful: {{ site.url }}/blog/{{ post.slug }}/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
      </a>
      <button type="button" class="blogpost-share__btn" data-copy-link data-url="{{ site.url }}/blog/{{ post.slug }}/" aria-label="Copy link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </aside>

  </div>

</article>

<!-- ════════════════════════════════════════════════════════════════════
     RELATED POSTS
     ════════════════════════════════════════════════════════════════════ -->
{% if related.length %}
<section class="section section--cream" aria-labelledby="related-posts-heading">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Keep Reading</span>
      <h2 id="related-posts-heading">More from the blog</h2>
    </div>
    <div class="blog-grid">
      {% for p in related %}
      <article class="blog-card reveal">
        <a href="/blog/{{ p.slug }}/" class="blog-card__media" tabindex="-1" aria-hidden="true">
          <img src="{{ p.image }}" alt="{{ p.imageAlt }}" loading="lazy" decoding="async" width="600" height="400">
          <span class="blog-tag blog-tag--on-image">{{ p.category }}</span>
        </a>
        <div class="blog-card__body">
          <h3 class="blog-card__title"><a href="/blog/{{ p.slug }}/">{{ p.title }}</a></h3>
          <p class="blog-card__excerpt">{{ p.excerpt }}</p>
          <div class="blog-meta">
            <time datetime="{{ p.date }}">{{ p.date | readableDate }}</time>
            <span class="blog-meta__dot" aria-hidden="true">·</span>
            <span>{{ p.readTime }} min</span>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
    <div style="text-align:center; margin-top:var(--space-6);">
      <a href="/blog/" class="btn btn--outline">View all articles</a>
    </div>
  </div>
</section>
{% endif %}

<!-- ════════════════════════════════════════════════════════════════════
     BOTTOM CTA
     ════════════════════════════════════════════════════════════════════ -->
<section class="section section--ink" aria-labelledby="post-cta-heading">
  <div class="container" style="text-align:center; max-width:680px;">
    <span class="eyebrow" style="color:var(--c-accent-soft);">Ready to See It in Person?</span>
    <h2 id="post-cta-heading" style="color:var(--c-cream);">Come visit Azalea Estates.</h2>
    <p style="color:rgba(250,246,241,.85); margin-bottom:var(--space-6);">Tours take about 60–90 minutes and include the full campus and a complimentary lunch. Questions are always welcome.</p>
    <a href="/schedule-a-tour/" class="btn btn--primary">Schedule a Tour</a>
    <a href="tel:{{ site.contact.phoneRaw }}" class="btn btn--outline" style="margin-left:var(--space-3);">{{ site.contact.phone }}</a>
  </div>
</section>
