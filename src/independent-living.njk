      { tag: 'One Bedroom',        size: '411', bed: 1, bath: 1,
        thumb: '/assets/images/thumb_azalea-estates-thumb-1bed-rev.jpg',
        pdf:   '/assets/pdfs/azalea-estates-fp-1bed-rev.pdf' },
      { tag: 'One Bedroom Deluxe', size: '624', bed: 1, bath: 1,
        thumb: '/assets/images/thumb_azalea-estates-thumb-1bed-deluxe-rev.jpg',
        pdf:   '/assets/pdfs/azalea-estates-fp-1bed-deluxe-rev.pdf' },
      { tag: 'Two Bedroom',        size: '680', bed: 2, bath: 1,
        thumb: '/assets/images/thumb_azalea-estates-thumb-2bed-rev.jpg',
        pdf:   '/assets/pdfs/azalea-estates-fp-2bed-rev.pdf' },
      { tag: 'Two Bedroom Deluxe', size: '925', bed: 2, bath: 2,
        thumb: '/assets/images/thumb_azalea-estates-thumb-2bed-deluxe-rev.jpg',
        pdf:   '/assets/pdfs/azalea-estates-fp-2bed-deluxe-rev.pdf' }
    ] -%}
    <div class="plans-grid">
      {% for p in plans %}
      <div class="plan-card reveal">
        <a href="{{ p.pdf }}" class="plan-card__thumb" data-pdf-url="{{ p.pdf }}" data-pdf-title="{{ p.tag }} Floor Plan" tabindex="-1" aria-hidden="true">
          <img src="{{ p.thumb }}" alt="{{ p.tag }} floor plan drawing" width="225" height="225" loading="lazy">
        </a>
        <h3>{{ p.tag }}</h3>
        <div class="plan-card__specs">
          <span><strong>{{ p.size }}</strong> sq. ft.</span>
          <span><strong>{{ p.bed }}</strong> Bed</span>
          <span><strong>{{ p.bath }}</strong> Bath</span>
        </div>
        <div class="plan-card__actions">
          <a href="{{ p.pdf }}" class="plan-card__pdf-link" data-pdf-url="{{ p.pdf }}" data-pdf-title="{{ p.tag }} Floor Plan" aria-label="View {{ p.tag }} floor plan">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false"><rect x="2" y="1" width="8" height="11" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M4 5h6M4 7.5h6M4 10h3.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
            View floor plan <span class="plan-card__pdf-label">PDF</span>
          </a>
        </div>
      </div>
      {% endfor %}
    </div>
    <div style="text-align:center; margin-top: var(--space-6);">
      <a href="/floor-plans/" class="btn btn--outline">View all floor plans &amp; request pricing</a>
    </div>
  </div>
</section>

