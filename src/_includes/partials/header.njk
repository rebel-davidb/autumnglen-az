{% from "partials/icons.njk" import icon %}
<header class="site-header">
  <div class="container header-top">
    <a href="tel:{{ site.contact.phoneRaw }}">{{ icon('phone', 14) }} {{ site.contact.phone }}</a>
    <a href="/events/">Events</a>
    <a href="/schedule-a-tour/">Schedule a Tour</a>
    <a href="/careers/">Careers</a>
  </div>
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="{{ site.name }} — Home">
      <img
        src="/assets/images/logo.png"
        alt="Azalea Estates — Assisted Living and Retirement Community"
        class="brand-logo"
        width="665"
        height="195"
        decoding="async"
      >
    </a>

    {# Hamburger — CSS spans animate to × when aria-expanded="true" #}
    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primaryNav">
      <span class="menu-toggle__bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <nav class="nav" id="primaryNav" aria-label="Primary">

      {# ── Mobile-only drawer header ─────────────────────────────────── #}
      <div class="nav-drawer-head">
        <a href="/" class="brand" aria-label="{{ site.name }} — Home" tabindex="-1">
          <img src="/assets/images/logo.png" alt="Azalea Estates" class="brand-logo" width="665" height="195" decoding="async" loading="lazy">
        </a>
        <button class="nav-drawer-close" aria-label="Close menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
            <path d="M3 3l14 14M17 3L3 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      {# ── Nav links ─────────────────────────────────────────────────── #}
      {% for item in site.nav %}
        {% if item.children %}
          <div class="nav-dropdown" data-dropdown>
            <a href="{{ item.url }}" class="nav-dropdown__trigger" aria-expanded="false" data-dropdown-trigger>
              {{ item.label }}
              <svg class="nav-dropdown__chevron" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true" focusable="false">
                <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="nav-dropdown__panel" role="menu">
              {% for child in item.children %}
                <a href="{{ child.url }}" role="menuitem">{{ child.label }}</a>
              {% endfor %}
              <a href="{{ item.url }}" class="nav-dropdown__all" role="menuitem">{{ item.allLabel }} <span aria-hidden="true">→</span></a>
            </div>
          </div>
        {% else %}
          <a href="{{ item.url }}">{{ item.label }}</a>
        {% endif %}
      {% endfor %}

      {# ── Desktop CTA ───────────────────────────────────────────────── #}
      <div class="nav-cta">
        <a href="/schedule-a-tour/" class="btn btn--primary">Schedule a Tour</a>
      </div>

      {# ── Mobile-only drawer footer ─────────────────────────────────── #}
      <div class="nav-drawer-foot">
        <a href="tel:{{ site.contact.phoneRaw }}" class="nav-drawer-phone">
          {{ icon('phone', 18) }}
          {{ site.contact.phone }}
        </a>
        <a href="/schedule-a-tour/" class="btn btn--primary">Schedule a Tour</a>
        <div class="nav-drawer-util-group">
          <a href="/events/" class="nav-drawer-util">Events</a>
          <a href="/calendar/" class="nav-drawer-util">Activity Calendar</a>
          <a href="/calendar/" class="nav-drawer-util">Wellness Calendar</a>
<a href="/careers/" class="nav-drawer-util">Careers</a>
        </div>
      </div>

    </nav>
  </div>
</header>

{# Backdrop — tapping it closes the mobile nav #}
<div class="nav-backdrop" id="navBackdrop" aria-hidden="true"></div>
