<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {# --- Title + description ------------------------------------------------ #}
  {# metaTitle is SEO-specific; title is the on-page H1 (auto-used as fallback). #}
  {%- set pageTitle = metaTitle or (title + ' | ' + site.name) if title else site.name -%}
  {%- set pageDesc  = description or site.description -%}
  {%- set canonical = site.url + (page.url or '/') -%}
  {%- set pageOgImage = (ogImage or images.hero) -%}
  {%- if pageOgImage and pageOgImage[0] == '/' %}{% set pageOgImage = site.url + pageOgImage %}{% endif -%}

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDesc }}">

  {# --- Crawler + canonical ------------------------------------------------ #}
  <link rel="canonical" href="{{ canonical }}">
  <meta name="robots" content="{% if noindex %}noindex,follow{% else %}index,follow,max-image-preview:large,max-snippet:-1{% endif %}">

  {# --- Local SEO geo tags (Fayette County, GA) --------------------------- #}
  <meta name="geo.region" content="US-GA">
  <meta name="geo.placename" content="Fayetteville, Georgia">
  <meta name="geo.position" content="33.4487;-84.4546">
  <meta name="ICBM" content="33.4487, -84.4546">

  {# --- Icons + theme ----------------------------------------------------- #}
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#375741">
  <meta name="format-detection" content="telephone=yes">

  {# --- Open Graph / Facebook --------------------------------------------- #}
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDesc }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="{{ pageOgImage }}">
  <meta property="og:image:alt" content="{{ images.heroAlt }}">

  {# --- Twitter Card ------------------------------------------------------ #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDesc }}">
  <meta name="twitter:image" content="{{ pageOgImage }}">
  <meta name="twitter:image:alt" content="{{ images.heroAlt }}">

  {# --- Fonts — loaded asynchronously to avoid render-blocking ------------ #}
  {# preconnect establishes early connections; the stylesheet loads via     #}
  {# onload so it never blocks the first paint. noscript provides fallback. #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload"
        as="style"
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600;700&display=swap"
        onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600;700&display=swap">
  </noscript>

  {# --- ActiveDemand tracking --------------------------------------------- #}
  <script src="https://data.staticfiles.io/accounts/8ceb53-c080d5-24ed0b/load.js" type="text/javascript" async defer></script>

  {# --- Styles ------------------------------------------------------------ #}
  <link rel="stylesheet" href="/assets/css/styles.css">

  {# --- Preload LCP image ------------------------------------------------- #}
  {# fetchpriority=high tells the browser to fetch this before other images #}
  {# so it arrives before the first paint. Covers both the home page video  #}
  {# poster (heroImage) and interior page heroes (pageHero).               #}
  {% if heroImage %}
  <link rel="preload" as="image" href="{{ heroImage }}" fetchpriority="high">
  {% elif pageHero %}
  <link rel="preload" as="image" href="{{ pageHero }}" fetchpriority="high">
  {% endif %}

  {# --- Homepage-only: preconnect to video CDN so the TCP handshake is     #}
  {# already done before the <video> element is parsed.                     #}
  {% if page.url == "/" %}
  <link rel="preconnect" href="https://seek-cdn.nyc3.cdn.digitaloceanspaces.com">
  <link rel="dns-prefetch" href="https://seek-cdn.nyc3.cdn.digitaloceanspaces.com">
  {% endif %}

  {# --- Structured data: Organization / SeniorLivingFacility -------------- #}
  {# Only emitted on the home page. Other pages cite @id to avoid duplication. #}
  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["SeniorLivingFacility", "LocalBusiness"],
    "@id": "{{ site.url }}/#org",
    "name": "{{ site.name }}",
    "alternateName": "{{ site.shortName }}",
    "description": "{{ site.description }}",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/assets/images/logo.png",
    "image": [
      "{{ site.url }}{{ images.hero }}",
      "{{ site.url }}{{ images.communityExterior }}",
      "{{ site.url }}{{ images.wellnessPool }}"
    ],
    "telephone": "{{ site.contact.phone }}",
    "email": "{{ site.contact.email }}",
    "priceRange": "$$",
    "foundingDate": "1993",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ site.contact.addressLine1 }}",
      "addressLocality": "Fayetteville",
      "addressRegion": "GA",
      "postalCode": "30215",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 33.4487,
      "longitude": -84.4546
    },
    "areaServed": [
      { "@type": "City", "name": "Fayetteville",   "containedInPlace": { "@type": "State", "name": "Georgia" } },
      { "@type": "City", "name": "Peachtree City", "containedInPlace": { "@type": "State", "name": "Georgia" } },
      { "@type": "City", "name": "Tyrone",         "containedInPlace": { "@type": "State", "name": "Georgia" } },
      { "@type": "City", "name": "Brooks",         "containedInPlace": { "@type": "State", "name": "Georgia" } },
      { "@type": "City", "name": "Woolsey",        "containedInPlace": { "@type": "State", "name": "Georgia" } },
      { "@type": "City", "name": "Senoia",         "containedInPlace": { "@type": "State", "name": "Georgia" } },
      { "@type": "City", "name": "Newnan",         "containedInPlace": { "@type": "State", "name": "Georgia" } },
      { "@type": "AdministrativeArea", "name": "Fayette County, Georgia" },
      { "@type": "AdministrativeArea", "name": "Greater Atlanta, Georgia" },
      { "@type": "AdministrativeArea", "name": "Southern Crescent, Georgia" }
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "{{ site.contact.phone }}",
      "contactType": "admissions",
      "email": "{{ site.contact.email }}",
      "areaServed": "US-GA",
      "availableLanguage": "English",
      "hoursAvailable": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "17:00"
      }
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "17:00",
        "description": "Private tours available"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "09:00",
        "closes": "12:00",
        "description": "By appointment"
      }
    ],
    "hasMap": "{{ site.contact.mapsUrl }}",
    "makesOffer": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Independent Living",
          "description": "Maintenance-free retirement apartment living in Fayetteville, GA with chef-prepared dining, wellness programs, and social activities.",
          "url": "{{ site.url }}/living-options/independent-living/",
          "areaServed": "Fayette County, Georgia"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Assisted Living",
          "description": "Licensed assisted living in Fayetteville, GA — one of only two State of Georgia licensed assisted living providers in Fayette County. Individualized care plans, on-site licensed RN and LPN.",
          "url": "{{ site.url }}/living-options/assisted-living/",
          "areaServed": "Fayette County, Georgia"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Respite Care",
          "description": "Short-term respite care in Fayetteville, GA for post-surgical recovery, caregiver relief, and trial stays. All-inclusive daily rate, fully furnished suites.",
          "url": "{{ site.url }}/living-options/respite-care/",
          "areaServed": "Fayette County, Georgia"
        }
      }
    ],
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Heated indoor saltwater aerobic pool",     "value": true },
      { "@type": "LocationFeatureSpecification", "name": "3000 sq ft wellness center",               "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Chef-prepared dining, 3 meals daily",      "value": true },
      { "@type": "LocationFeatureSpecification", "name": "24-hour on-site staffing",                 "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Licensed RN and LPN on-site",              "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Full-service salon and barbershop",        "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Courtesy transportation Mon-Fri",          "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Pet-friendly suites",                      "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Single-story accessible campus",           "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Parkinson's exercise program",             "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Community garden and walking paths",       "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Library and computer room",                "value": true }
    ],
    "sameAs": [
      "{{ site.social.facebook }}"
    ],
    "keywords": "assisted living Fayetteville GA, senior living Fayetteville Georgia, retirement community Fayette County, independent living Peachtree City GA, respite care Fayetteville, senior care Fayette County"
  }
  </script>
  {% endif %}

  {# --- Structured data: Breadcrumbs (interior pages only) ---------------- #}
  {# 3-level for /living-options/* sub-pages; 2-level for everything else. #}
  {% if page.url != "/" and page.url != "/404.html" %}
  {% set isCarePage = page.url.startsWith("/living-options/") and page.url != "/living-options/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" }{% if isCarePage %},
      { "@type": "ListItem", "position": 2, "name": "Living Options", "item": "{{ site.url }}/living-options/" },
      { "@type": "ListItem", "position": 3, "name": "{{ title | safe }}", "item": "{{ canonical }}" }{% else %},
      { "@type": "ListItem", "position": 2, "name": "{{ title | safe }}", "item": "{{ canonical }}" }{% endif %}
    ]
  }
  </script>
  {% endif %}

  {# --- Structured data: WebSite (home only, enables sitelinks search) ---- #}
  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "{{ site.url }}/#website",
    "url": "{{ site.url }}",
    "name": "{{ site.name }}",
    "publisher": { "@id": "{{ site.url }}/#org" },
    "inLanguage": "en-US"
  }
  </script>
  {% endif %}
</head>
<body>
  {# GTM noscript fallback — only active after consent is given via JS above.
     The container ID is intentionally left blank here; GTM is loaded
     dynamically by main.js only after the user accepts cookies. #}
  <a href="#main" class="skip-link">Skip to main content</a>
  {% include "partials/header.njk" %}

  <!-- Announcement bar — links to high-value content sections -->
  <nav class="announce-bar" aria-label="Quick links">
    <div class="announce-bar__inner container">
      <a href="/events/">Upcoming Events</a>
      <a href="/calendar/">Activity &amp; Wellness Calendars</a>
      <a href="/team/">Meet Our Team</a>
      <a href="/living-options/#respite">Try a Respite Stay</a>
    </div>
  </nav>

  <main id="main">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <!-- PDF Viewer Modal
       Triggered by any element with data-pdf-url attribute.
       PDF.js is lazy-loaded from cdnjs on first use. -->
  <div class="pdfv" id="pdfViewer" role="dialog" aria-modal="true" aria-labelledby="pdfViewerTitle" hidden>
  <div class="pdfv__panel">

    <!-- Header bar: title + controls -->
    <header class="pdfv__header">
      <span class="pdfv__title" id="pdfViewerTitle"></span>
      <div class="pdfv__controls" role="toolbar" aria-label="PDF viewer controls">

        <!-- Zoom out -->
        <button class="pdfv__btn pdfv__zoom-out" aria-label="Zoom out">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 7h5M11 11l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>

        <!-- Zoom level -->
        <span class="pdfv__zoom-label" aria-live="polite" aria-atomic="true">100%</span>

        <!-- Zoom in -->
        <button class="pdfv__btn pdfv__zoom-in" aria-label="Zoom in">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M7 4.5v5M4.5 7h5M11 11l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>

        <div class="pdfv__sep" aria-hidden="true"></div>

        <!-- Print -->
        <button class="pdfv__btn pdfv__print" aria-label="Print">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="3" y="6" width="10" height="7" rx="1" stroke="currentColor" stroke-width="1.4"/><path d="M5 6V3h6v3M5 10h6M5 12h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          <span class="pdfv__btn-label">Print</span>
        </button>

        <!-- Download -->
        <a class="pdfv__btn pdfv__download" href="#" aria-label="Download PDF">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2v8M5 7l3 3 3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span class="pdfv__btn-label">Download</span>
        </a>

        <div class="pdfv__sep" aria-hidden="true"></div>

        <!-- Close -->
        <button class="pdfv__btn pdfv__close" aria-label="Close PDF viewer">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>

      </div>
    </header>

    <!-- Scrollable page stage -->
    <div class="pdfv__stage">
      <div class="pdfv__pages" id="pdfPages" aria-live="polite"></div>
    </div>

  </div><!-- /.pdfv__panel -->
  </div>

  <!-- Gallery lightbox
       Accessible: focus-trapped, Escape closes, ArrowLeft/Right navigate,
       focus returns to opening thumbnail on close. -->
  <div class="lightbox" role="dialog" aria-modal="true" aria-labelledby="lightbox-caption">
    <button class="lightbox__close" aria-label="Close photo viewer">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false">
        <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <button class="lightbox__prev" aria-label="Previous photo">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true" focusable="false">
        <path d="M14 17l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="lightbox__stage">
      <div class="lightbox__frame">
        <img src="" alt="" class="lightbox__img">

        {# Zoom HUD — bottom-right of the frame #}
        <div class="lightbox__zoom-hud" aria-hidden="true">
          <div class="lightbox__zoom-legend">
            <span class="zoom-legend__item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
              Scroll to zoom
            </span>
            <span class="zoom-legend__item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M6 14v-2"/><path d="M6 12a2 2 0 0 0-2 2v2a6 6 0 0 0 12 0v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2"/></svg>
              Drag to pan
            </span>
            <span class="zoom-legend__item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
              Double-click to reset
            </span>
          </div>
          <div class="lightbox__zoom-controls">
            <button class="zoom-btn" data-zoom="in"    aria-label="Zoom in">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </button>
            <span class="zoom-level">100%</span>
            <button class="zoom-btn" data-zoom="out"   aria-label="Zoom out">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </button>
            <button class="zoom-btn" data-zoom="reset" aria-label="Reset zoom">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.59"/></svg>
            </button>
          </div>
        </div>
      </div>
      <div class="lightbox__footer">
        <p class="lightbox__caption" id="lightbox-caption"></p>
        <span class="lightbox__counter" aria-hidden="true"></span>
      </div>
    </div>

    <button class="lightbox__next" aria-label="Next photo">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true" focusable="false">
        <path d="M8 5l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Screen-reader live region announces photo changes during navigation -->
    <span class="sr-only" aria-live="polite" aria-atomic="true" id="lightbox-status"></span>
  </div>

  <!-- "Try It, You'll Like It" toast — shown once to new visitors -->
  <div class="tryit-toast" id="tryitToast" role="complementary" aria-label="Special offer" hidden>
    <button class="tryit-toast__close" id="tryitClose" aria-label="Dismiss offer">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
        <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="tryit-toast__eyebrow">Try It, You&rsquo;ll Like It</div>
    <p class="tryit-toast__heading">Be a Resident for the Day.</p>
    <p class="tryit-toast__body">Come spend a full day with us, Monday through Friday, 8&thinsp;am to 6:30&thinsp;pm. Experience the meals, the people, and the community firsthand. No obligation.</p>
    <div class="tryit-toast__actions">
      <a href="tel:7625725194" class="btn btn--primary tryit-toast__cta">Call Mirna to RSVP</a>
      <span class="tryit-toast__phone">(762) 572-5194</span>
    </div>
  </div>


  <!-- Cookie consent banner -->
  <div class="cookie-banner" id="cookieBanner" role="region" aria-label="Cookie notice" hidden>
    <div class="cookie-banner__inner">
      <p class="cookie-banner__text">
        We use cookies to understand how visitors use our site and to improve your experience.
        No personal health information is collected.
        <a href="/privacy/">Privacy Policy</a>
      </p>
      <div class="cookie-banner__actions">
        <button class="cookie-banner__accept" id="cookieAccept">Accept</button>
        <button class="cookie-banner__decline" id="cookieDecline">Decline</button>
      </div>
    </div>
  </div>

  <!-- Guided Tour Ribbon -->
  <div class="tour-ribbon" id="tourRibbon" hidden aria-label="Guided tour" role="region">
    <div class="tour-ribbon__inner">
      <div class="tour-ribbon__steps" id="tourSteps" aria-hidden="true"></div>
      <div class="tour-ribbon__body">
        <span class="tour-ribbon__label">Guided Tour</span>
        <span class="tour-ribbon__stop" id="tourStopName"></span>
      </div>
      <div class="tour-ribbon__controls">
        <button class="tour-ribbon__btn tour-ribbon__btn--prev" id="tourPrev" aria-label="Previous stop">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <span class="tour-ribbon__counter" id="tourCounter" aria-live="polite"></span>
        <button class="tour-ribbon__btn tour-ribbon__btn--next" id="tourNext" aria-label="Next stop">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <button class="tour-ribbon__exit" id="tourExit" aria-label="Exit guided tour">
          <svg width="13" height="13" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M2 2l14 14M16 2L2 16"/></svg>
        </button>
      </div>
    </div>
    <div class="tour-ribbon__progress" id="tourProgress"></div>
  </div>

  <script src="/assets/js/main.js" defer></script>
  {# pdf-viewer.js only loads on pages that actually have PDFs — saves     #}
  {# an unnecessary download on the home page, gallery, contact, etc.      #}
  {% if hasPdfs %}
  <script src="/assets/js/pdf-viewer.js" defer></script>
  {% endif %}
</body>
</html>
