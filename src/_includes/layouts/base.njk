<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {# --- Title + description ------------------------------------------------ #}
  {# metaTitle is SEO-specific; title is the on-page H1 (auto-used as fallback). #}
  {%- set pageTitle = metaTitle or (title + ' | ' + site.name) if title else site.name -%}
  {%- set pageDesc  = description or site.description -%}
  {%- set canonical = site.url + (page.url or '/') -%}
  {%- set pageOgImage = (ogImage or images.hero) -%}
  {%- if pageOgImage and pageOgImage[0] == '/' %}{% set pageOgImage = site.url + pageOgImage %}{% endif -%}

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDesc }}">

  {# --- Crawler + canonical ------------------------------------------------ #}
  <link rel="canonical" href="{{ canonical }}">
  <meta name="robots" content="{% if noindex %}noindex,follow{% else %}index,follow,max-image-preview:large,max-snippet:-1{% endif %}">

  {# --- Local SEO geo tags (Fayette County, GA) --------------------------- #}
  <meta name="geo.region" content="US-GA">
  <meta name="geo.placename" content="Fayetteville, Georgia">
  <meta name="geo.position" content="33.4487;-84.4546">
  <meta name="ICBM" content="33.4487, -84.4546">

  {# --- Icons + theme ----------------------------------------------------- #}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="theme-color" content="#213b14">
  <meta name="format-detection" content="telephone=yes">

  {# --- Open Graph / Facebook --------------------------------------------- #}
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDesc }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="{{ pageOgImage }}">
  <meta property="og:image:alt" content="{{ images.heroAlt }}">

  {# --- Twitter Card ------------------------------------------------------ #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDesc }}">
  <meta name="twitter:image" content="{{ pageOgImage }}">
  <meta name="twitter:image:alt" content="{{ images.heroAlt }}">

  {# --- Fonts ------------------------------------------------------------- #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600;700&display=swap">

  {# --- Styles ------------------------------------------------------------ #}
  <link rel="stylesheet" href="/assets/css/styles.css">

  {# --- Preload hero image for LCP ---------------------------------------- #}
  {% if heroImage %}
  <link rel="preload" as="image" href="{{ heroImage }}" fetchpriority="high">
  {% endif %}

  {# --- Structured data: Organization / SeniorLivingFacility -------------- #}
  {# Only emitted on the home page. Other pages cite @id to avoid duplication. #}
  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["SeniorLivingFacility", "LocalBusiness"],
    "@id": "{{ site.url }}/#org",
    "name": "{{ site.name }}",
    "alternateName": "{{ site.shortName }}",
    "description": "{{ site.description }}",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/assets/images/logo.png",
    "image": [
      "{{ site.url }}{{ images.hero }}",
      "{{ site.url }}{{ images.communityExterior }}",
      "{{ site.url }}{{ images.wellnessPool }}"
    ],
    "telephone": "{{ site.contact.phone }}",
    "email": "{{ site.contact.email }}",
    "priceRange": "$$",
    "foundingDate": "1993",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ site.contact.addressLine1 }}",
      "addressLocality": "Fayetteville",
      "addressRegion": "GA",
      "postalCode": "30215",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 33.4487,
      "longitude": -84.4546
    },
    "areaServed": [
      { "@type": "City", "name": "Fayetteville, GA" },
      { "@type": "City", "name": "Peachtree City, GA" },
      { "@type": "City", "name": "Tyrone, GA" },
      { "@type": "AdministrativeArea", "name": "Fayette County, GA" },
      { "@type": "AdministrativeArea", "name": "Greater Atlanta, GA" }
    ],
    "makesOffer": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Independent Living", "url": "{{ site.url }}/living-options/#independent" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Assisted Living",    "url": "{{ site.url }}/living-options/#assisted" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Respite Care",       "url": "{{ site.url }}/living-options/#respite" } }
    ],
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Heated indoor saltwater aerobic pool", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Chef-prepared dining",                  "value": true },
      { "@type": "LocationFeatureSpecification", "name": "24-hour on-site staffing",              "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Licensed on-site nursing",              "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Full-service salon & barbershop",       "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Courtesy transportation",               "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Pet-friendly suites",                   "value": true }
    ],
    "sameAs": [
      "{{ site.social.facebook }}"
    ]
  }
  </script>
  {% endif %}

  {# --- Structured data: Breadcrumbs (interior pages only) ---------------- #}
  {% if page.url != "/" and page.url != "/404.html" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
      { "@type": "ListItem", "position": 2, "name": "{{ title | safe }}", "item": "{{ canonical }}" }
    ]
  }
  </script>
  {% endif %}

  {# --- Structured data: WebSite (home only, enables sitelinks search) ---- #}
  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "{{ site.url }}/#website",
    "url": "{{ site.url }}",
    "name": "{{ site.name }}",
    "publisher": { "@id": "{{ site.url }}/#org" },
    "inLanguage": "en-US"
  }
  </script>
  {% endif %}
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  {% include "partials/header.njk" %}

  <main id="main">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <!-- Gallery lightbox root -->
  <div class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="lightbox__close" aria-label="Close image">×</button>
    <img src="" alt="">
  </div>

  <script src="/assets/js/main.js" defer></script>
</body>
</html>
