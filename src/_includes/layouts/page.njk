---
layout: layouts/base.njk
---
<section class="page-hero{% if heroAccent == 'accent' %} page-hero--accent{% endif %}">
  <div class="page-hero__panel">
    <div class="page-hero__inner">
      <p class="crumbs"><a href="/">Home</a> <span>/</span> <span>{{ title | safe }}</span></p>
      {% if eyebrow %}<span class="eyebrow">{{ eyebrow | safe }}</span>{% endif %}
      <h1>{{ title | safe }}</h1>
      {% if pageIntro %}<p>{{ pageIntro | safe }}</p>{% endif %}
    </div>
  </div>
  <div class="page-hero__media">
    <img src="{{ pageHero or images.communityExterior }}" alt="" loading="eager">

    {# Expand/collapse button — bottom left #}
    <button
      type="button"
      class="page-hero__expand"
      aria-label="View full-size photo"
      aria-expanded="false"
    >
      <span class="page-hero__expand-icon" aria-hidden="true">
        <svg class="icon-expand" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
        <svg class="icon-collapse" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/></svg>
      </span>
      <span class="page-hero__expand-label">View full size</span>
    </button>

  </div>
</section>

{{ content | safe }}
